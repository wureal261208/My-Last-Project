rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /bookwormUsers/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // Prototype rule for public book data: guest users can still add views and comments.
    // Tighten this before production if admin-only book/staff editing is required.
    match /bookwormData/global {
      allow read: if true;
      allow write: if true;
    }

    match /bookwormComments/{bookId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
