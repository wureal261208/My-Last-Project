PORT=4000
CLIENT_ORIGIN=http://127.0.0.1:5173

# MongoDB Atlas connection string (Atlas dashboard -> Connect -> Drivers).
# Never commit the real value - only server/.env (gitignored) should hold it.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=schema

# Comma-separated list of emails always treated as admin.
ADMIN_EMAILS=admin@bookworm.test

# Full Firebase service-account JSON as a single line.
# Firebase Console -> Project settings -> Service accounts -> Generate new private key.
FIREBASE_SERVICE_ACCOUNT=

# How often (ms) the background worker checks Firestore <-> MongoDB staff/role data for changes.
SYNC_INTERVAL_MS=15000

# Used to sign JWT access tokens (server/routes/auth.js). Generate your own with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
