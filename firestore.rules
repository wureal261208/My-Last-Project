rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isCoopStaff() {
      return signedIn()
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "co-op-admin"
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "employee"
        );
    }

    function isVip() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "vip";
    }

    match /books/{bookId} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow create: if isAdmin() || isCoopStaff();
      allow update, delete: if isAdmin()
        || (isCoopStaff() && resource.data.ownerId == request.auth.uid);
    }

    match /users/{uid} {
      allow read: if isAdmin() || request.auth.uid == uid;
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if isAdmin() || request.auth.uid == uid;
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /user-library/{uid}/books/{bookId} {
      allow read: if isAdmin() || request.auth.uid == uid;
      allow write: if isAdmin();
    }

    match /co-op/{coopId} {
      allow read, write: if isAdmin();
    }
  }
}
